{
  "name": "connecker",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@connecker/web",
    "dev:dashboard": "turbo dev --filter=@connecker/dashboard",
    "dev:admin": "turbo dev --filter=@connecker/admin",
    "build:web": "turbo build --filter=@connecker/web",
    "build:dashboard": "turbo build --filter=@connecker/dashboard",
    "build:admin": "turbo build --filter=@connecker/admin"
  },
  "dependencies": {
    "next": "^14.2.0"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
